{
  "version": 2,
  "builds": [{ "src": "api/index.js", "use": "@vercel/node" }],
  "routes": [{ "src": "/(.*)", "dest": "api/index.js" }],
  "functions": {
    "api/index.js": {
      "includeFiles": "storefront/**"
    }
  },
  "crons": [
    {
      "path": "/api/cron/sync-catalog",
      "schedule": "0 6 * * *"
    }
  ]
}
