{
  "name": "boxplus-deciplus",
  "version": "1.0.0",
  "private": true,
  "description": "Analyse et automatisation Deciplus pour Boxing Center (PrestaShop → Deciplus)",
  "scripts": {
    "analyze:record": "node analyzer/record-session.js",
    "analyze:scenario": "node analyzer/run-scenario.js",
    "analyze:report": "node analyzer/generate-report.js",
    "bot:run": "node bot/index.js",
    "start:bot": "node start.js",
    "bridge:start": "node bridge/server.js",
    "store:start": "node storefront/server.js",
    "store:sync": "node storefront/scripts/sync-and-test.js",
    "stripe:listen": "node storefront/scripts/stripe-listen.js",
    "test": "node --test test/*.test.js",
    "test:offers": "node --test test/all-offers.test.js",
    "test:offers:live": "node scripts/test-all-offers.js --live",
    "test:load": "node test/load-queue.test.js",
    "vercel-build": "echo Vercel build OK"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "playwright": "^1.51.1",
    "stripe": "^17.7.0"
  }
}
