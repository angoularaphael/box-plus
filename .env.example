# Deciplus
DECIPLUS_URL=https://manager.deciplus.pro
DECIPLUS_USER=
DECIPLUS_PASSWORD=
DECIPLUS_HEADLESS=false
DECIPLUS_SLOW_MO=100

# Analyzer
ANALYZER_SCENARIO=login
ANALYZER_OUTPUT_DIR=analyzer/output

# Bot
BOT_DATA_DIR=data
BOT_SESSION_DIR=data/session
BOT_MAX_RETRIES=3
BOT_MIN_DELAY_MS=1000
BOT_MAX_DELAY_MS=3000

# Bridge (PrestaShop → BOXPLUS)
BRIDGE_PORT=3030
BRIDGE_SECRET=change-me-in-production
BRIDGE_HOST=0.0.0.0

# Boutique présentation (Stripe → BOXPLUS)
STORE_PORT=3040
STORE_URL=http://localhost:3040
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STORE_SYNC_ENABLED=true
STORE_SYNC_INTERVAL_MS=21600000
SYNC_SECRET=change-me-in-production
BOXPLUS_BRIDGE_URL=http://localhost:3030
# Sur Vercel : BOXPLUS_QUEUE_DIR=/tmp/boxplus-queue

# Alertes (optionnel)
ALERT_WEBHOOK_URL=
ALERT_EMAIL=
