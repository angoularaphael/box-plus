# === Copier ce fichier en .env dans /home/container/ sur KataBump ===

# Repo bot (optionnel — défaut GitHub boxi-deci-bot)
BOT_REPO_URL=https://github.com/angoularaphael/boxi-deci-bot.git
BOT_REPO_BRANCH=main

# Deciplus
DECIPLUS_URL=https://boxingcenter.deciplus.pro/
DECIPLUS_USER=BRAD
DECIPLUS_PASSWORD=remplir
DECIPLUS_HEADLESS=true
DECIPLUS_SLOW_MO=50

# HTTP — port KataBump (Network tab)
BOT_HTTP_PORT=20029

# Secret partagé avec Vercel (IDENTIQUE des 2 côtés)
SYNC_SECRET=boxplus-test-2026-change-moi

# Push catalogue → boutique Vercel
STORE_INGEST_URL=https://box-plus.vercel.app/api/admin/ingest-catalog

# Bot
BOT_POLL_MS=5000
BOT_MAX_RETRIES=3
BOT_CATALOG_PUSH_ENABLED=true
BOT_CATALOG_PUSH_MS=21600000
